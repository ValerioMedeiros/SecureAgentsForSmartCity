# Smart City Traffic Management - Configuration Example
# Copy this file to .env and fill in with your actual values

# ============================================
# OpenAI / LLM Configuration
# ============================================

# Set to "true" to automatically execute plans generated by the LLM planner
EXECUTE_PLANS=true

# Enable LLM-based planning (set to "true" to enable)
LLM_PLANNER_ENABLED=true

# OpenAI API key (required if LLM_PLANNER_ENABLED=true)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model to use for planning
OPENAI_MODEL=gpt-4o-mini

# LLM temperature for plan generation

LLM_TEMPERATURE=0.3

# ============================================
# Traffic Signal Configuration
# ============================================

TRAFFIC_SIGNAL_ID=TrafficSignal:001

# ============================================
# User Authentication
# ============================================

USER_TOKEN=user-token
HUMAN_APPROVAL_TOKEN=human-approval-token

# ============================================
# OPA (Open Policy Agent) Configuration
# ============================================

# Set to enable OPA-based policy evaluation
# Leave empty to use fallback policy engine
OPA_URL=
OPA_POLICY_PATH=v1/data/smartcity/allow
OPA_TIMEOUT_SECONDS=1.5

# ============================================
# API Server Configuration
# ============================================

MCP_SERVER_URL=http://localhost:8000/mcp

# ============================================
# Logging Configuration
# ============================================

LOG_LEVEL=INFO